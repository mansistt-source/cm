# ── Core ──────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://your-app.example.com
JWT_SECRET=generate-at-least-32-random-characters
CREDENTIAL_ENCRYPTION_KEY=generate-another-32-random-characters
DATABASE_URL=mysql://user:pass@host:3306/contentmachine

# ── Google One Tap Login ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── AI — Claude + Higgsfield ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HIGGSFIELD_API_KEY=...

# ── PayPal ────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...
PAYPAL_PLAN_STARTER=...
PAYPAL_PLAN_GROWTH=...
PAYPAL_PLAN_PRO=...
PAYPAL_PLAN_AGENCY=...

# ── Forge Storage ─────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=...
BUILT_IN_FORGE_API_KEY=...

# ── Social Publishing ─────────────────────────────────────────
INSTAGRAM_CLIENT_ID=...
INSTAGRAM_CLIENT_SECRET=...
YOUTUBE_CLIENT_ID=...
